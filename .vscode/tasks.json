{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "noop",
			"type": "shell",
			"command": "echo done"
		},
		{
			"label": "bugfix: test (typecheck + build + full battery)",
			"type": "shell",
			"command": "npm run bugfix:test",
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"problemMatcher": ["$tsc"]
		},
		{
			"label": "bugfix: release (prompt for description)",
			"type": "shell",
			"command": "powershell -ExecutionPolicy Bypass -File scripts/bugfix-release.ps1 -Description \"${input:fixDescription}\"",
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"problemMatcher": []
		},
		{
			"label": "Start MemPalace MCP Server",
			"type": "shell",
			"command": "$env:CF_DEV_MODE='agent'; node infrastructure/mempalace_watchdog.js --once; if ($LASTEXITCODE -ne 0) { node infrastructure/mempalace_watchdog.js --once; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE } }; node infrastructure/mempalace_watchdog.js --watch --intervalMs 3000",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"focus": false,
				"panel": "dedicated",
				"showReuseMessage": false,
				"clear": false
			},
			"problemMatcher": [],
			"runOptions": {
				"runOn": "folderOpen"
			}
		},
		{
			"label": "Start MemPalace Watchdog",
			"type": "shell",
			"command": "node infrastructure/mempalace_watchdog.js --watch --intervalMs 3000",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"focus": false,
				"panel": "dedicated",
				"showReuseMessage": false,
				"clear": false
			},
			"problemMatcher": []
		},
		{
			"label": "bugfix: dry run (tests only, no publish)",
			"type": "shell",
			"command": "powershell -ExecutionPolicy Bypass -File scripts/bugfix-release.ps1 -Description \"${input:fixDescription}\" -DryRun",
			"group": "test",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"problemMatcher": ["$tsc"]
		},
		{
			"label": "CourseForge: Setup (Windows)",
			"type": "shell",
			"command": "scripts/setup-courseforge.windows.ps1",
			"isBackground": false,
			"problemMatcher": [],
			"windows": {
				"options": {
					"shell": {
						"executable": "powershell",
						"args": [
							"-NoProfile",
							"-ExecutionPolicy",
							"Bypass",
							"-File"
						]
					}
				}
			}
		},
		{
			"label": "CourseForge: Setup (macOS)",
			"type": "shell",
			"command": "bash scripts/setup-courseforge.macos.sh",
			"isBackground": false,
			"problemMatcher": [],
			"osx": {
				"options": {
					"shell": {
						"executable": "/bin/bash",
						"args": [
							"-lc"
						]
					}
				}
			}
		},
		{
			"label": "CourseForge: Setup (Linux)",
			"type": "shell",
			"command": "bash scripts/setup-courseforge.linux.sh",
			"isBackground": false,
			"problemMatcher": [],
			"linux": {
				"options": {
					"shell": {
						"executable": "/bin/bash",
						"args": [
							"-lc"
						]
					}
				}
			}
		},
		{
			"label": "CourseForge: Install Recommended VS Code Extensions",
			"type": "shell",
			"command": "node scripts/print-vscode-extension-commands.mjs",
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "CourseForge: Verify MCP Servers",
			"type": "shell",
			"command": "node scripts/verify-mcp-servers.mjs",
			"isBackground": false,
			"problemMatcher": []
		}
	],
	"inputs": [
		{
			"id": "fixDescription",
			"type": "promptString",
			"description": "Brief description of the bug fix (used in commit message and release notes)",
			"default": "Bug fix"
		}
	]
}