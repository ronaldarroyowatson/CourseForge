{
  "name": "courseforge-functions",
  "version": "1.4.2",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "check:runtime": "node ../scripts/check-node-version.mjs --min 20 --max 21 --label functions --strict",
    "build": "npm run check:runtime && tsc",
    "serve": "npm run check:runtime && firebase emulators:start --only functions",
    "deploy": "npm run check:runtime && firebase deploy --only functions"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^6.0.1",
    "mammoth": "^1.9.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
