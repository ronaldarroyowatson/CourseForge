{
  "name": "courseforge",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:extension": "vite build --config vite.extension.config.ts",
    "typecheck": "tsc --noEmit",
    "test:core": "tsx tests/core/runCoreTests.ts",
    "test:integration": "vitest run tests/integration",
    "test": "npm run test:core ; npm run test:integration"
  },
  "dependencies": {
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "idb": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.4",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^28.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
