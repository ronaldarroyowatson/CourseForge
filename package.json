{
  "name": "courseforge",
  "version": "1.5.8",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "check:node": "node scripts/check-node-version.mjs --min 20 --max 25 --label workspace",
    "check:node:functions": "node scripts/check-node-version.mjs --min 20 --max 21 --label functions --strict",
    "check:node:next24": "node scripts/check-node-version.mjs --min 24 --max 25 --label next-node-canary",
    "functions:build:compat": "node scripts/run-functions-compat.mjs build",
    "functions:serve:compat": "node scripts/run-functions-compat.mjs serve",
    "functions:deploy:compat": "node scripts/run-functions-compat.mjs deploy",
    "verify:stable": "npm run check:node && npm run check:node:functions && npm run typecheck:all && npm run build && npm run build:extension && npm test && npm run check:installer && npm --prefix functions run build",
    "verify:canary": "npm run check:node:next24 && npm run typecheck:all && npm run build && npm run build:extension && npm test && npm run check:installer && npm run functions:build:compat",
    "dev": "vite",
    "webapp": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:extension": "vite build --config vite.extension.config.ts",
    "build:extension:chrome": "vite build --config vite.chrome-extension.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck:scripts",
    "test:index": "node scripts/generate-test-index.mjs",
    "test:samples:validate": "node scripts/validate-test-samples.mjs",
    "program": "node scripts/program-cli.mjs",
    "courseforge": "node scripts/program-cli.mjs",
    "test:core": "tsx tests/core/runCoreTests.ts",
    "test:unit": "vitest run tests/core",
    "test:integration": "vitest run tests/integration",
    "test:e2e:webapp": "vitest run tests/integration/app.integration.test.tsx tests/integration/autoTextbookFlow.integration.test.tsx tests/integration/documentIngest.panel.integration.test.tsx tests/integration/startupSync.probe.test.tsx tests/integration/settings.updater.integration.test.tsx",
    "test:e2e:ocr": "vitest run tests/core/autoOcrService.test.ts tests/core/metadataExtractionPipelineService.test.ts tests/integration/autoTextbookFlow.integration.test.tsx",
    "test:e2e:extension": "vitest run tests/integration/extension.auth.communication.integration.test.ts tests/integration/extension.repositories.integration.test.ts",
    "test:e2e:autoupdate": "vitest run tests/integration/auto-update-portable.integration.test.ts tests/integration/auto-update-launcher.integration.test.ts tests/integration/update-status-server.integration.test.ts tests/integration/settings.updater.integration.test.tsx",
    "test:e2e": "npm run test:e2e:ocr && npm run test:e2e:webapp && npm run test:e2e:extension && npm run test:e2e:autoupdate",
    "test:e2e:comprehensive": "npm run test:e2e && npm run test:core && npm run test:unit && npm run test:integration && npm run test:rules",
    "test:comprehensive": "npm run test:e2e:comprehensive",
    "test:e2e:no-rules": "npm run test:e2e && npm run test:core && npm run test:unit && npm run test:integration",
    "test:smoke:ocr:cloud": "powershell -ExecutionPolicy Bypass -File scripts/smoke-cloud-ocr.ps1",
    "test:smoke:ocr:cloud:gate": "node scripts/run-cloud-ocr-smoke-gate.mjs",
    "test:e2e:packaged": "npm run test:e2e:autoupdate && npm run test:installer && npm run check:installer",
    "test:real-sync": "tsx tests/realSyncTest.ts",
    "test:installer:guardrails": "vitest run tests/integration/windows.installer.template.integration.test.ts",
    "test:installer:lifecycle": "vitest run tests/core/installerLifecycle.test.ts tests/core/installerLifecycle.matrix.test.ts",
    "test:installer": "npm run test:installer:lifecycle && npm run test:installer:guardrails",
    "probe:startup-sync": "vitest run tests/integration/startupSync.probe.test.tsx --reporter=verbose",
    "test:rules": "tsx tests/rules/runRulesTests.ts",
    "package:portable": "powershell -ExecutionPolicy Bypass -File scripts/create-portable-package.ps1",
    "verify:portable": "powershell -ExecutionPolicy Bypass -File scripts/verify-portable-package.ps1",
    "package:windows": "powershell -ExecutionPolicy Bypass -File scripts/create-windows-package.ps1",
    "package:windows:gui": "powershell -ExecutionPolicy Bypass -File scripts/create-windows-package.ps1 -RequireGuiInstaller",
    "package:windows:legacy": "powershell -ExecutionPolicy Bypass -File scripts/create-windows-package.ps1 -AllowLegacyBootstrap -EmitWindowsZip",
    "verify:windows": "powershell -ExecutionPolicy Bypass -File scripts/verify-windows-package.ps1",
    "check:installer": "npm run package:portable && npm run verify:portable && npm run package:windows && npm run verify:windows",
    "check:installer:gui": "npm run package:portable && npm run verify:portable && npm run package:windows:gui && npm run verify:windows",
    "quality:installer": "npm run test:installer && npm run check:installer",
    "quality:installer:gui": "npm run test:installer && npm run check:installer:gui",
    "deploy:firestore": "firebase deploy --only firestore",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:backend": "firebase deploy --only firestore,functions",
    "test": "npm run test:core && npm run test:unit && npm run test:integration && npm run test:rules",
    "bugfix:test": "npm run typecheck:all && npm run test:index && npm run test:samples:validate && npm run build && npm run test:e2e:comprehensive && npm run test:smoke:ocr:cloud:gate",
    "bugfix:release": "powershell -ExecutionPolicy Bypass -File scripts/bugfix-release.ps1"
  },
  "dependencies": {
    "@azure/cosmos": "^4.9.1",
    "firebase": "^12.10.0",
    "idb": "^8.0.0",
    "jszip": "^3.10.1",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@dillip285/mcp-terminal": "^1.0.1",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.4",
    "fake-indexeddb": "^6.0.0",
    "firebase-tools": "^15.10.0",
    "jsdom": "^28.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.2",
    "@types/node": "^24.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
