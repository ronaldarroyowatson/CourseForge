{
  "manifest_version": 3,
  "name": "CourseForge Sidebar",
  "version": "0.1.0",
  "description": "Quick curriculum capture for CourseForge.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "index.html",
    "default_title": "CourseForge"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "index.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
